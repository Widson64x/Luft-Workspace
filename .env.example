APP_NAME=Luft Hub
APP_ENV=development
APP_SECRET_KEY=trocar_em_producao

# Configuracao de SSO entre sistemas Flask/LuftCore
# Os mesmos valores devem ser replicados nos demais projetos (ex: Luft-Control).
SESSION_COOKIE_NAME=luft_sessao
SESSION_COOKIE_PATH=/
# Exemplo em producao: .luftfarma.com.br
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SAMESITE=Lax
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_NAME=luft_sessao_remember
# Opcional: expira sessao permanente em minutos.
PERMANENT_SESSION_LIFETIME_MINUTES=720

HOST=127.0.0.1
PORT=9010
ROUTE_PREFIX=
LUFT_USAR_PREFIXO_MENSAGENS=false

SISTEMA_ID=0
DEBUG_PERMISSIONS=false

LDAP_SERVER=luftfarma.com.br
LDAP_DOMAIN=luftfarma

VAULT_ADDR=http://172.16.200.80:8200
VAULT_NAMESPACE=luft
VAULT_SQLSERVER_PATH=luft/desenvolvimento/sqlserver
VAULT_TOKEN=<TOKEN_VAULT_CRIPTOGRAFADO>
TOKEN_ACESSO=<TOKEN_ACESSO_DO_FRAMEWORK>
AMBIENTE_ATUAL=desenvolvimento

DB_DRIVER=ODBC Driver 17 for SQL Server
SQLDB_TRUST_SERVER_CERTIFICATE=yes

# Operacoes de servico (preencha com o nome real do servico Windows)
LUFT_WORKSPACE_SERVICE_NAME=
LUFT_CONTROL_SERVICE_NAME=
LUFT_CONNECTAIR_SERVICE_NAME=
LUFT_DOCS_WEB_SERVICE_NAME=
LUFT_DOCS_API_SERVICE_NAME=
LUFT_INTEGRADOR_SERVICE_NAME=
NGINX_SERVICE_NAME=

# Descoberta dinamica de projetos (.env/.venv) por ambiente
# Use ';' no Windows e ',' ou ';' em Linux.
OPERACOES_SCAN_ROOTS=

# Override opcional de caminho absoluto por projeto
WORKSPACE_PROJECT_DIR=
LUFT_CONTROL_PROJECT_DIR=
LUFT_CONNECTAIR_PROJECT_DIR=
LUFT_DOCS_PROJECT_DIR=
LUFT_INTEGRADOR_PROJECT_DIR=
